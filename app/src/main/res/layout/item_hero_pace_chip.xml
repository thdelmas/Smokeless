<?xml version="1.0" encoding="utf-8"?>
<!-- One row of the hero pace chip. For single-substance users only one row
     is inflated and textHeroPaceSubstanceLabel is hidden. For multi-
     substance users (tobacco + cannabis dogfooders) two rows stack and
     each carries its own delta badge so the verdict isn't a misleading
     pool of unlike substances. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:layout_marginTop="0dp"
    android:background="@drawable/bg_stat_chip">

    <TextView
        android:id="@+id/textHeroPaceSubstanceLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_tertiary"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textHeroPaceDelta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="28sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.02"
        android:includeFontPadding="false"
        android:visibility="gone"
        android:contentDescription="Number of cigarettes ahead of or behind your usual pace" />

    <TextView
        android:id="@+id/textHeroPaceCopy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:accessibilityLiveRegion="polite" />

</LinearLayout>
