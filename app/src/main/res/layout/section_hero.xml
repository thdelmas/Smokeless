<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- App Branding -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿 Smokeless"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08" />

        <!-- Motivational Message -->
        <TextView
            android:id="@+id/textViewMotivation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Every hour counts"
            android:textColor="@color/accent_primary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:alpha="0.9" />

    </LinearLayout>

    <!-- Main Timer Card -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:id="@+id/cardCurrentScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_hero_card"
            android:paddingTop="32dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="24dp"
            android:gravity="center">

            <!-- Status Badge -->
            <TextView
                android:id="@+id/textStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:background="@drawable/bg_stat_chip"
                android:text="🌟 Going Strong"
                android:textColor="@color/accent_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/labelCurrentStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WAIT BEFORE NEXT"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif-medium" />

            <!-- Big Countdown Timer Display -->
            <TextView
                android:id="@+id/textViewCurrentScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="00:00:00"
                android:textColor="@color/accent_primary"
                android:textSize="56sp"
                android:fontFamily="sans-serif-black"
                android:includeFontPadding="false"
                android:letterSpacing="-0.02"
                android:contentDescription="Countdown to next allowed cigarette"
                android:accessibilityLiveRegion="polite" />

            <!-- Contextual Message -->
            <TextView
                android:id="@+id/textStreakContext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Keep going, you're doing great!"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:gravity="center" />

            <!-- Goal Progress Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_stat_chip"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textGoalProgressLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Goal Progress"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/textViewGoalLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Target: --"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/textViewPercentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/accent_primary"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black" />

                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:indicatorColor="@color/accent_primary"
                    app:trackColor="@color/progress_track"
                    app:trackCornerRadius="8dp"
                    app:trackThickness="12dp"
                    android:contentDescription="Goal progress indicator" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
