<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="10dp"
        android:text="Trigger windows"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:fontFamily="sans-serif-medium" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/card_border_dim">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ When you typically smoke"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Hour-of-day pattern over the last 30 days."
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/textTriggerHeadsUp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_stat_chip"
                android:text=""
                android:textColor="@color/accent_amber"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"
                android:accessibilityLiveRegion="polite" />

            <LinearLayout
                android:id="@+id/groupTriggerWindows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/textTriggerEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Log a few more days to surface your trigger windows."
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Why this matters: cravings cluster around specific hours — usually anchored to coffee, commute, meals, or end-of-day. Naming the windows turns the next craving from a surprise into a forecast you can plan around."
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.35"
                android:fontFamily="sans-serif" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
